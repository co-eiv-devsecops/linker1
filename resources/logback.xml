<configuration>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="OTEL" class="io.opentelemetry.instrumentation.logback.appender.v1_0.OpenTelemetryAppender">
        <captureExperimentalAttributes>true</captureExperimentalAttributes>
        <captureCodeAttributes>true</captureCodeAttributes>
        <captureMdcAttributes>*</captureMdcAttributes>
    </appender>

    <!-- The application's own log verbosity is controlled entirely by the
         LOG_LEVEL environment variable (see docs/LOGGING.md). Third-party
         libraries are pinned to INFO regardless, so setting LOG_LEVEL=TRACE
         to debug the app doesn't flood the output with Jetty/SQLite internals. -->
    <logger name="linker" level="${LOG_LEVEL:-INFO}" />
    <logger name="Main" level="${LOG_LEVEL:-INFO}" />

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="OTEL" />
    </root>

</configuration>
